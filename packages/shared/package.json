{
  "name": "@workslocal/shared",
  "version": "0.1.0",
  "private": true,
  "description": "WorksLocal shared types, schemas, constants, and utilities",
  "repository": {
    "type": "git",
    "url": "https://github.com/083chandan/workslocal",
    "directory": "packages/shared"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
